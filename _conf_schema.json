{
  "groups": {
    "type": "template_list",
    "description": "QQ 群 API 配置列表（每个群独立设置 Ayabot 连接参数）",
    "hint": "添加每个需要查询的 QQ 群及其对应的 Ayabot 连接信息。群成员绑定 B站 UID 后即可查询。",
    "templates": {
      "group_config": {
        "name": "群配置",
        "display_item": "group_id",
        "hint": "添加一个 QQ 群的 Ayabot API 配置",
        "items": {
          "group_id": {
            "description": "QQ 群号",
            "type": "string",
            "default": ""
          },
          "api_url": {
            "description": "Ayabot 服务地址",
            "hint": "例如 http://192.168.1.100:19810",
            "type": "string",
            "default": ""
          },
          "api_token": {
            "description": "API 密钥",
            "hint": "从 Ayabot WebUI → 数据管理 → 复制密钥",
            "type": "string",
            "default": ""
          },
          "room_id": {
            "description": "房间号",
            "hint": "可留空",
            "type": "string",
            "default": ""
          }
        }
      }
    }
  },
  "bindings_file": {
    "description": "QQ-UID 绑定数据文件路径（全局通用）",
    "hint": "相对于 AstrBot data 目录",
    "type": "string",
    "default": "ayabot_bindings.json"
  }
}
